# Copy to .env.local and fill in. Never commit real keys.

# OpenAI - used for Whisper transcription and LLM transcript cleanup.
OPENAI_API_KEY=replace_me_openai_api_key

# Optional: override the cleanup model. Defaults to gpt-4o-mini.
OPENAI_PROCESSING_MODEL=gpt-4o-mini

# Notion integration token.
# Create one at https://notion.so/my-integrations (grant Read + Insert content),
# then share your notes database with the integration.
NOTION_API_KEY=replace_me_notion_integration_token

# 32-char database ID from the Notion DB URL:
# https://notion.so/<workspace>/<DATABASE_ID>?v=...
NOTION_DATABASE_ID=your-notion-database-id

# Data source ID used for querying recent notes.
# In Notion SDK v5 this is separate from the database ID.
NOTION_DATA_SOURCE_ID=your-notion-data-source-id
